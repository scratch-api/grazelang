{
  ".rs": {
    "single_line": {
      "comment_regex": "(//[ \\t\\f\\v]*TODO:.*(?:\\n[ \\t\\f\\v]*//.*)*)",
      "name_regex": "TODO:[ \\t\\f\\v]*(.*)",
      "content_regex": "//(.*)",
      "content_sub": "$1\n",
      "add_issue_sub": "$1\n{{ indent }}// {{ issue_str }}"
    },
    "multi_line": {
      "comment_regex": "(/\\*(\\s*TODO:[\\s\\S]*?)\\*/)",
      "name_regex": "TODO:\\s*([^\\n\\r*]*)",
      "content_regex": "(?:^|\\n)\\s*\\*?(.*?)(?=\\*/|\\n|$)",
      "content_sub": "$1\n",
      "add_issue_sub": "/*$2\n{{ indent }} {{ issue_str }}*/"
    }
  }
}